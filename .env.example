# Passed as build args to the frontend Docker image.
# Copy to .env and fill in your values before running docker compose.

# Base URL of your solar API — no trailing slash
VITE_API_BASE_URL=http://your-api-host:8000

# Optional overrides (defaults shown)
# VITE_PRICE_WINDOW_PAST_HOURS=4
# VITE_PRICE_WINDOW_FUTURE_HOURS=10
# VITE_PROPERTIES_POLL_MS=10000
# VITE_PRICES_POLL_MS=300000
