# Base URL of the solar API — no trailing slash
# In dev, point directly at your local API server
# In production, leave empty if nginx proxies API paths,
# or set to the API address baked in at docker build time
VITE_API_BASE_URL=http://1.1.1.1:1111

# How many hours of past prices to fetch (default: 4)
VITE_PRICE_WINDOW_PAST_HOURS=4

# How many hours of forecast prices to fetch (default: 10)
VITE_PRICE_WINDOW_FUTURE_HOURS=10

# Properties polling interval in milliseconds (default: 10000)
VITE_PROPERTIES_POLL_MS=10000

# Prices polling interval in milliseconds (default: 300000 = 5 min)
VITE_PRICES_POLL_MS=300000
